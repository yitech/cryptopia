# --- Cryptopia backend ---
# Where SQLite + notebook files live
CRYPTOPIA_DATA_DIR=./data
CRYPTOPIA_DATABASE_URL=sqlite+aiosqlite:///./data/cryptopia.db

# Public hostname the platform is served from (used for absolute URLs in OG tags etc.)
CRYPTOPIA_PUBLIC_URL=https://dashboards.lynxlinkage.com

# CORS / forwarded base path. Leave empty if served at root.
CRYPTOPIA_BASE_URL=

# --- Authelia (forward-auth) ---
# Required header names. The reverse proxy MUST set these from Authelia
# (these are Authelia's defaults, change only if you customised them).
CRYPTOPIA_AUTH_HEADER_USER=Remote-User
CRYPTOPIA_AUTH_HEADER_EMAIL=Remote-Email
CRYPTOPIA_AUTH_HEADER_NAME=Remote-Name
CRYPTOPIA_AUTH_HEADER_GROUPS=Remote-Groups

# Authelia portal URL. Used to build login redirect links from the frontend.
CRYPTOPIA_AUTHELIA_URL=https://auth.lynxlinkage.com

# Trust X-Forwarded-* headers (you usually want this when behind a reverse proxy).
CRYPTOPIA_TRUST_FORWARDED=true

# --- Local development bypass ---
# When CRYPTOPIA_DEV_AUTH_USER is set AND no Remote-User header is present,
# the backend will pretend the request was authenticated as this user.
# Leave empty in production.
CRYPTOPIA_DEV_AUTH_USER=
CRYPTOPIA_DEV_AUTH_EMAIL=
CRYPTOPIA_DEV_AUTH_NAME=
CRYPTOPIA_DEV_AUTH_GROUPS=

# --- Marimo edit subprocess ---
# Idle timeout (seconds) before an edit session subprocess is killed.
CRYPTOPIA_EDIT_IDLE_TIMEOUT=1800
# Port range for edit subprocesses.
CRYPTOPIA_EDIT_PORT_RANGE_START=42000
CRYPTOPIA_EDIT_PORT_RANGE_END=42999

# --- Frontend (SvelteKit) ---
PUBLIC_API_BASE=
PUBLIC_AUTHELIA_URL=https://auth.lynxlinkage.com
