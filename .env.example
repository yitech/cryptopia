# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://cryptopia:cryptopia@localhost:5432/cryptopia

# Security — generate with: openssl rand -hex 32
SECRET_KEY=please-change-this-to-a-random-256-bit-key

# Storage paths
REPOS_DIR=/var/cryptopia/repos
NOTEBOOKS_DIR=/var/cryptopia/notebooks

# CORS — comma-separated frontend origin(s)
ALLOWED_ORIGINS=["http://localhost:5173"]

# Public URL of the frontend (required by SvelteKit's CSRF protection when running the Node build)
# Set this to wherever users access the app, e.g. https://cryptopia.yourdomain.com
ORIGIN=http://localhost:3000

# Optional
DEBUG=false
